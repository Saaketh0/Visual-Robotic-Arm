<?xml version="1.0"?>
<robot name="hiwonder_xarm_1s_approx">

  <!--
    Approximate visual/kinematic URDF for Hiwonder xArm 1S.
    Units: meters, radians.
    Coordinate convention:
      X = arm reaches forward
      Y = left/right
      Z = up
  -->

  <!-- ===================== Materials ===================== -->

  <material name="black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>

  <material name="dark_gray">
    <color rgba="0.15 0.15 0.15 1"/>
  </material>

  <material name="silver">
    <color rgba="0.65 0.65 0.65 1"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.25 1.0 1"/>
  </material>

  <material name="red">
    <color rgba="1.0 0.05 0.05 1"/>
  </material>

  <material name="yellow">
    <color rgba="1.0 0.75 0.0 1"/>
  </material>

  <!-- ===================== Base ===================== -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0175" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.12 0.025"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <!-- ===================== Joint 1: base yaw ===================== -->

  <joint name="joint_1_base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="turret_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094" upper="2.094" effort="5.0" velocity="2.0"/>
  </joint>

  <link name="turret_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.050"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <visual>
      <origin xyz="0.025 0 0.070" rpy="0 0 0"/>
      <geometry>
        <box size="0.080 0.070 0.080"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- ===================== Joint 2: shoulder pitch ===================== -->

  <joint name="joint_2_shoulder_pitch" type="revolute">
    <parent link="turret_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0.040 0 0.090" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="2.0"/>
  </joint>

  <link name="upper_arm_link">
    <!-- Servo/bracket at shoulder -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.060"/>
      </geometry>
      <material name="red"/>
    </visual>

    <!-- Upper arm body -->
    <visual>
      <origin xyz="0.065 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.130 0.035 0.045"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <!-- ===================== Joint 3: elbow pitch ===================== -->

  <joint name="joint_3_elbow_pitch" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.130 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="2.0"/>
  </joint>

  <link name="forearm_link">
    <!-- Elbow servo/bracket -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.055"/>
      </geometry>
      <material name="red"/>
    </visual>

    <!-- Forearm body -->
    <visual>
      <origin xyz="0.060 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.120 0.032 0.040"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <!-- ===================== Joint 4: wrist pitch ===================== -->

  <joint name="joint_4_wrist_pitch" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0.120 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="3.0" velocity="2.0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.050"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <visual>
      <origin xyz="0.040 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.080 0.030 0.035"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <!-- ===================== Joint 5: wrist roll ===================== -->

  <joint name="joint_5_wrist_roll" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0.080 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="3.0" velocity="2.0"/>
  </joint>

  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0.020 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.023" length="0.040"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- ===================== Gripper palm ===================== -->

  <joint name="gripper_mount_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_palm_link"/>
    <origin xyz="0.040 0 0" rpy="0 0 0"/>
  </joint>

  <link name="gripper_palm_link">
    <visual>
      <origin xyz="0.030 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.060 0.030"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <!-- ===================== Gripper fingers ===================== -->

  <joint name="left_gripper_joint" type="prismatic">
    <parent link="gripper_palm_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0.060 0.025 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.020" effort="1.0" velocity="0.2"/>
  </joint>

  <link name="left_finger_link">
    <visual>
      <origin xyz="0.030 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.012 0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="right_gripper_joint" type="prismatic">
    <parent link="gripper_palm_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0.060 -0.025 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.020" effort="1.0" velocity="0.2"/>
    <mimic joint="left_gripper_joint" multiplier="1.0" offset="0.0"/>
  </joint>

  <link name="right_finger_link">
    <visual>
      <origin xyz="0.030 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.012 0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

</robot>
